# Neon Postgres (Vercel-linked, auto-set in prod). Lokal manuell eintragen.
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Stripe (Test-Mode first, dann Live). Setup via stripe CLI + 1Password.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_EVENT_PASS=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_STUDIO_MONTHLY=
STRIPE_PRICE_STUDIO_YEARLY=

# Auth (next-auth v5)
AUTH_SECRET=
AUTH_URL=

# DSGVO: Salt für IP/Fingerprint-Hash. MUSS in Prod gesetzt sein.
# Generieren: openssl rand -hex 32
BEATCONTROL_HASH_PEPPER=

# AI (Groq für Genre + Empfehlungen)
GROQ_API_KEY=
